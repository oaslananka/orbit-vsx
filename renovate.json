{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "timezone": "Europe/Istanbul",
  "schedule": ["before 6am on monday"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Dashboard",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "branchConcurrentLimit": 8,
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "rebaseWhen": "behind-base-branch",
  "vulnerabilityAlerts": {
    "enabled": true,
    "prCreation": "immediate",
    "automerge": false,
    "labels": ["dependencies", "security", "priority:P1", "theme:supply-chain"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"],
    "automerge": false,
    "labels": ["dependencies", "area:ci", "theme:supply-chain"]
  },
  "packageRules": [
    {
      "description": "Do not auto-raise the supported VS Code or Node runtime floor.",
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "matchPackageNames": ["vscode", "node"],
      "enabled": false
    },
    {
      "description": "The VS Code API type floor follows engines.vscode and requires an explicit compatibility decision.",
      "matchPackageNames": ["@types/vscode"],
      "enabled": false
    },
    {
      "description": "Keep @types/node on the supported Node 22 major until the runtime floor changes.",
      "matchPackageNames": ["@types/node"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Automerge low-risk patch, pin, and digest updates after protected checks pass.",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["dependencies", "risk:low"]
    },
    {
      "description": "Automerge minor development-tool updates after protected checks pass.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["dependencies", "area:ci", "risk:low"]
    },
    {
      "description": "Automerge non-major GitHub Action updates while keeping immutable digests.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest", "patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["dependencies", "area:ci", "theme:supply-chain"]
    },
    {
      "description": "Review major updates manually.",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "risk:high"]
    },
    {
      "description": "Review compatibility-sensitive minor updates manually.",
      "matchPackageNames": [
        "typescript",
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom",
        "esbuild",
        "@vscode/test-cli",
        "@vscode/test-electron",
        "@vscode/vsce",
        "ovsx"
      ],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "labels": ["dependencies", "area:compatibility", "risk:medium"]
    },
    {
      "description": "Group React runtime and type updates for one compatibility review.",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "React ecosystem"
    },
    {
      "description": "Group TypeScript and ESLint toolchain updates.",
      "matchPackageNames": [
        "typescript",
        "eslint",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser"
      ],
      "groupName": "TypeScript lint toolchain"
    },
    {
      "description": "Let the custom regex manager own the digest-only headless Node image.",
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["tools/headless/Dockerfile"],
      "enabled": false
    },
    {
      "description": "Review Trivy release updates manually because the archive checksum must be refreshed.",
      "matchPackageNames": ["aquasecurity/trivy"],
      "automerge": false,
      "labels": ["dependencies", "area:ci", "area:security", "risk:medium"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update the pinned Renovate config validator version.",
      "managerFilePatterns": ["/^package\\.json$/"],
      "matchStrings": ["renovate@(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "renovate",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update the pinned Semgrep CLI in CI and pre-commit.",
      "managerFilePatterns": [
        "/^\\.pre-commit-config\\.yaml$/",
        "/^\\.github/workflows/semgrep\\.yml$/"
      ],
      "matchStrings": ["semgrep==(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "semgrep",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update the pinned Snyk CLI used by the security workflow.",
      "managerFilePatterns": ["/^package\\.json$/"],
      "matchStrings": ["snyk@(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "snyk",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update the version and digest of the non-root headless Node image.",
      "managerFilePatterns": ["/^tools\\/headless\\/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=docker depName=(?<depName>\\S+)\\n# version: (?<currentValue>\\S+)\\nFROM (?<packageName>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update the pinned Codecov CLI used by both report uploads.",
      "managerFilePatterns": ["/^\\.github/workflows/codecov\\.yml$/"],
      "matchStrings": ["version: v(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "codecov/codecov-cli",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update the pinned pre-commit runner used by workflow security CI.",
      "managerFilePatterns": ["/^\\.github/workflows/workflow-security\\.yml$/"],
      "matchStrings": ["pre-commit==(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "pre-commit",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update the checksum-pinned Trivy release version; checksum review remains manual.",
      "managerFilePatterns": ["/^scripts/run-trivy-config-scan\\.sh$/"],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=(?<depName>\\S+)\\nTRIVY_VERSION='(?<currentValue>\\d+\\.\\d+\\.\\d+)'"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
